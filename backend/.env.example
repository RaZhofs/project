PORT=3001

DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=conglomerado_db
DB_USER=conglomerado_user
DB_PASSWORD=tu_password_aqui
# DB_INSTANCE=SQLEXPRESS   <- descomenta si usas named instance (ej. localhost\SQLEXPRESS)

# ── Correo Gmail (producción) ──────────────────────────────────────────────
# Usa una "Contraseña de Aplicación" de 16 dígitos generada en:
# https://myaccount.google.com/apppasswords
# (requiere tener verificación en dos pasos activa en la cuenta Gmail)
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Correo SMTP genérico (alternativo) ────────────────────────────────────
# Si se dejan vacíos EMAIL_USER/EMAIL_PASS, se intenta con estas variables.
# Si ambos bloques están vacíos, se usa Ethereal (modo demo — ver consola).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Convexa <noreply@convexa.com>
